# Copiez ce fichier en .env et adaptez les valeurs.

# Connexion PostgreSQL (doit correspondre au docker-compose.yml)
DATABASE_URL=postgresql+psycopg2://attendance:attendance@localhost:5432/attendance

# Sécurité JWT — générez une clé aléatoire en production :
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=changez-cette-cle-en-production
ACCESS_TOKEN_EXPIRE_MINUTES=480
