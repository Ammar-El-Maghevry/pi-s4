SECRET_KEY=changeme-generate-with-python -c "import secrets; print(secrets.token_urlsafe(48))"

# LAN IP this machine is reachable at from phones (used only to generate the
# frontend's self-signed HTTPS cert for the /phone-camera pairing page).
TLS_SAN_IP=192.168.1.10

# SMTP (used to email the /phone-camera pairing link). Leave SMTP_HOST empty
# to disable sending. Example values below are for a Mailtrap sandbox inbox.
# Port 465 = implicit TLS; 587/25/2525 = STARTTLS (controlled by SMTP_USE_TLS).
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=587
SMTP_USERNAME=changeme
SMTP_PASSWORD=changeme
SMTP_FROM_EMAIL=no-reply@presence.sys
SMTP_USE_TLS=true

# Origin the emailed pairing link points to. Only used directly if you're NOT
# running via the provided docker-compose (which derives this from TLS_SAN_IP
# automatically) — otherwise this default is overridden and safe to ignore.
PHONE_PAIRING_BASE_URL=https://192.168.1.10:8443
